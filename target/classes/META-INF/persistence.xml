<?xml version="1.0" encoding="UTF-8"?>

<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             version="3.0"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
             https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">

    <persistence-unit name="meuPU" transaction-type="RESOURCE_LOCAL">

        <!-- Provedor JPA (Hibernate) -->
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <!-- Aqui você pode listar suas entidades (opcional se usar auto-scan) -->
        <!-- <class>com.seuprojeto.Aluno</class> -->

        <properties>

            <!-- 🔌 Conexão com o banco -->
            <property name="jakarta.persistence.jdbc.url"
                      value="jdbc:mysql://localhost:3306/escola?useSSL=false&amp;serverTimezone=UTC&amp;characterEncoding=UTF-8"/>

            <property name="jakarta.persistence.jdbc.user" value="root"/>
            <property name="jakarta.persistence.jdbc.password" value=""/>
            <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>

            <!-- 🧠 Dialeto do banco -->
            <property name="hibernate.dialect"
                      value="org.hibernate.dialect.MySQLDialect"/>

            <!-- ⚙️ Controle de criação de tabelas -->
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            
            <!-- opções:
                 create  -> recria tudo (apaga dados)
                 update  -> atualiza sem apagar
                 validate -> só valida
                 none    -> não faz nada
            -->

            <!-- 🧾 Mostrar SQL no console -->
            <property name="hibernate.show_sql" value="true"/>

            <!-- 🧾 Formatar SQL -->
            <property name="hibernate.format_sql" value="true"/>

        </properties>

    </persistence-unit>

</persistence>